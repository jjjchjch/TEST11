build cmake/stm32cubemx/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D D:\CUBEproject\TEST11\build\Debug\cmake\stm32cubemx && C:\arm-tools\cmake-3.31.6-windows-x86_64\bin\cmake-gui.exe -SD:\CUBEproject\TEST11 -BD:\CUBEproject\TEST11\build\Debug"
  DESC = Running CMake cache editor...
  pool = console
  restat = 1

build cmake/stm32cubemx/edit_cache: phony cmake/stm32cubemx/CMakeFiles/edit_cache.util


